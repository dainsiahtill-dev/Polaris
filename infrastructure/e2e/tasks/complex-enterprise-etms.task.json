{
  "prompt": "政事堂创建企业级任务管理系统，包含用户认证JWT、任务CRUD、任务分配、进度跟踪、WebSocket通知、PostgreSQL数据库、Prisma ORM、Swagger文档、Jest测试、多租户支持、角色权限控制、甘特图数据接口、PDF导出功能",
  "gateConfig": {
    "strictErrors": true,
    "strictTerminalErrors": true,
    "startupSettleMs": 2000,
    "postActionSettleMs": 1200
  },
  "navigationSteps": [
    {
      "name": "open-settings",
      "selectorCandidates": [
        "button:has(svg.lucide-settings)",
        ".btn-icon:has(svg.lucide-settings)",
        "[data-testid='open-settings']",
        "button[aria-label='Settings']",
        "button[title='Settings']"
      ],
      "textCandidates": ["设置", "Settings"],
      "role": "button",
      "timeoutMs": 5000
    },
    {
      "name": "open-llm-settings",
      "selectorCandidates": [
        "[data-testid='settings-tab-llm']",
        "[role='tab']:has-text(\"LLM 设置\")",
        "button:has-text(\"LLM 设置\")",
        "button:has-text(\"LLM设置\")"
      ],
      "textCandidates": ["LLM设置", "LLM 设置", "模型设置", "LLM"],
      "role": "button",
      "timeoutMs": 5000
    },
    {
      "name": "open-provider-anthropic-compat",
      "selectorCandidates": [
        "[data-provider-type='anthropic_compat'] [data-provider-action='edit']",
        "[data-provider-type='anthropic_compat'] button[title='编辑提供商']",
        "[data-testid^='provider-edit-button-anthropic']"
      ],
      "textCandidates": ["Anthropic", "Claude"],
      "role": "button",
      "timeoutMs": 8000
    }
  ],
  "fieldAction": {
    "name": "complex-project-goal",
    "selectorCandidates": [
      "[data-testid='anthropic-model-id-input']",
      "[data-testid='architect-goal-input']",
      "textarea[name='goal']",
      "input[name='goal']"
    ],
    "labelCandidates": ["圣意目标", "目标", "Goal", "项目目标"],
    "placeholderCandidates": ["例：", "目标", "goal", "project"],
    "inputValue": "企业级任务管理系统：Express+TypeScript+Prisma+PostgreSQL+JWT+WebSocket+Swagger+Jest+多租户+RBAC权限+甘特图+PDF导出",
    "expectContains": "任务管理"
  }
}
