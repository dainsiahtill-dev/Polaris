{
  "name": "polaris-desktop",
  "private": true,
  "version": "0.1.0",
  "main": "src/electron/main.cjs",
  "scripts": {
    "setup:dev": "node infrastructure/scripts/setup-dev-env.js",
    "setup:python": "node infrastructure/scripts/setup-dev-env.js --python-only",
    "setup:node": "node infrastructure/scripts/setup-dev-env.js --node-only",
    "predev": "node infrastructure/scripts/setup-dev-env.js --predev",
    "dev": "node infrastructure/scripts/run-dev.js",
    "dev:renderer": "vite --config src/frontend/vite.config.ts",
    "dev:electron": "node infrastructure/scripts/wait-and-run-electron.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:electron": "npm run test:e2e",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:backend:shard": "python infrastructure/scripts/run-backend-pytest-shard.py",
    "lint": "eslint \"src/frontend/src/**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit -p src/frontend/tsconfig.json",
    "build": "npm run build:renderer",
    "build:renderer": "vite build --config src/frontend/vite.config.ts",
    "start": "node infrastructure/scripts/run-electron.js",
    "e2e:prepare": "npm run build:renderer",
    "test:e2e": "playwright test -c playwright.electron.config.ts",
    "pretest:e2e": "npm run e2e:prepare",
    "test:e2e:smoke": "playwright test -c playwright.electron.config.ts src/backend/polaris/tests/electron/app.spec.ts src/backend/polaris/tests/electron/realtime-visibility.spec.ts src/backend/polaris/tests/electron/panel-error.spec.ts",
    "pretest:e2e:smoke": "npm run e2e:prepare",
    "test:e2e:runtime": "playwright test -c playwright.electron.config.ts src/backend/polaris/tests/electron/app.spec.ts src/backend/polaris/tests/electron/realtime-visibility.spec.ts",
    "pretest:e2e:runtime": "npm run e2e:prepare",
    "test:e2e:acceptance": "node --env-file-if-exists=.env infrastructure/scripts/run-electron-acceptance-e2e.mjs",
    "pretest:e2e:acceptance": "npm run e2e:prepare",
    "test:e2e:real-flow": "node --env-file-if-exists=.env infrastructure/scripts/run-electron-real-flow-e2e.mjs",
    "pretest:e2e:real-flow": "npm run e2e:prepare",
    "test:e2e:panel": "playwright test -c playwright.electron.config.ts src/backend/polaris/tests/electron/panel-error.spec.ts",
    "pretest:e2e:panel": "npm run e2e:prepare",
    "test:e2e:task": "node --env-file-if-exists=.env infrastructure/scripts/run-panel-task-e2e.mjs",
    "test:e2e:semantic": "node --env-file-if-exists=.env infrastructure/scripts/run-stagehand-panel-task.mjs",
    "computer:openai": "node --env-file-if-exists=.env infrastructure/scripts/openai-computer-use-adapter.mjs",
    "vision:omniparser": "node --env-file-if-exists=.env infrastructure/scripts/run-omniparser-adapter.mjs",
    "auto:fix:panel": "node --env-file-if-exists=.env infrastructure/scripts/auto-fix-panel-task.mjs",
    "auto:fix:real-flow": "node --env-file-if-exists=.env infrastructure/scripts/auto-fix-real-flow.mjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@monaco-editor/react": "^4.7.0",
    "@radix-ui/react-accordion": "^1.1.2",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-aspect-ratio": "^1.0.3",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-collapsible": "^1.0.3",
    "@radix-ui/react-context-menu": "^2.1.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-hover-card": "^1.0.7",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-menubar": "^1.0.4",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-scroll-area": "^1.0.5",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.0.3",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toggle": "^1.0.3",
    "@radix-ui/react-toggle-group": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@react-three/drei": "^9.107.0",
    "@react-three/fiber": "^8.16.8",
    "@tanstack/react-query": "^5.99.0",
    "@types/dompurify": "^3.0.5",
    "@xyflow/react": "^12.10.0",
    "antd": "^6.3.1",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "dompurify": "^3.3.1",
    "embla-carousel-react": "^8.0.0",
    "framer-motion": "^12.29.2",
    "immer": "^11.1.4",
    "input-otp": "^1.2.4",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.474.0",
    "next-themes": "^0.4.6",
    "node-pty": "^1.1.0",
    "react": "^18.2.0",
    "react-day-picker": "^8.10.0",
    "react-diff-viewer-continued": "^4.1.2",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.51.0",
    "react-icons": "^5.5.0",
    "react-resizable-panels": "^2.0.19",
    "react-virtuoso": "^4.18.1",
    "recharts": "^2.12.0",
    "sonner": "^1.4.0",
    "tailwind-merge": "^2.2.1",
    "three": "^0.165.0",
    "tw-animate-css": "^1.2.0",
    "typecheck": "^0.1.2",
    "vaul": "^0.9.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "electron": "^30.0.0",
    "electron-builder": "^26.7.0",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsdom": "^28.0.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.18",
    "wait-on": "^7.2.0"
  }
}
