    "non_stream": {
      "required_tools": ["read_file"],
      "required_any_tools": [
        ["search_code", "repo_rg", "grep", "glob"]
      ],
      "forbidden_tools": ["execute_command", "search_replace", "edit_file"],
      "min_tool_calls": 2,
      "max_tool_calls": 4
    },
    "parity": {
      "required": true,
      "compare_mode": "set"
    }
  }
