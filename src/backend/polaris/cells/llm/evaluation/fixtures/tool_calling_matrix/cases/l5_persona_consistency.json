{
  "case_id": "l5_persona_consistency",
  "level": "L5",
  "role": "director",
  "title": "L5 Persona Consistency — Tool Call Accuracy Under Persona",
  "description": "验证不同 persona 配置下，模型仍能准确调用工具，不因角色扮演而破坏工具调用准确性。",
  "workspace_fixture": "base_tooling_workspace",
  "prompt": "读取 config.py 告诉我 API_HOST 和 API_PORT 的值。",
  "tags": ["l5", "persona", "consistency", "tool_accuracy"],
  "weight": 1.0,
  "critical": true,
  "judge": {
    "score_threshold": 0.80,
    "stream": {
      "required_tools": ["read_file"],
      "min_tool_calls": 1,
      "max_tool_calls": 1,
      "first_tool": "read_file",
      "first_call_arg_equals": {
        "file": "config.py"
      },
      "required_output_substrings": ["127.0.0.1", "49977"],
      "forbidden_tools": ["execute_command", "write_file"],
      "persona_agnostic": true
    },
    "non_stream": {
      "required_tools": ["read_file"],
      "min_tool_calls": 1,
      "max_tool_calls": 1,
      "required_output_substrings": ["127.0.0.1", "49977"],
      "persona_agnostic": true
    },
    "parity": {
      "required": true,
      "compare_mode": "set"
    }
  }
}
