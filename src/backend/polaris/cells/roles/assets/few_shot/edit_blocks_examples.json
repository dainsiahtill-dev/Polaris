{\n  \"description\": \"EDIT_BLOCKS 工具 Few-shot 示例库 - SEARCH/REPLACE 格式\",\n  \"version\": \"1.0.0\",\n  \"examples\": [\n    {\n      \"id\": \"python_simple_function\",\n      \"language\": \"python\",\n      \"scenario\": \"简单函数修改\",\n      \"difficulty\": \"easy\",\n      \"user_request\": \"给这个函数添加类型提示\",\n      \"context\": \"src/calculator.py\",\n      \"original_code\": \"def add(a, b):\\n    return a + b\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:src/calculator.py\\ndef add(a, b):\\n    return a + b\\n====\\ndef add(a: int, b: int) -> int:\\n    return a + b\\n>>>> REPLACE\"\n      },\n      \"notes\": \"基本缩进保留和类型提示添加\"\n    },\n    {\n      \"id\": \"python_error_handling\",\n      \"language\": \"python\",\n      \"scenario\": \"添加错误处理\",\n      \"difficulty\": \"easy\",\n      \"user_request\": \"处理空列表情况\",\n      \"context\": \"src/median.py\",\n      \"original_code\": \"    if not values:\\n        return 0\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:src/median.py\\n    if not values:\\n        return 0\\n====\\n    if not values:\\n        raise ValueError(\\\"Cannot compute median of empty list\\\")\\n>>>> REPLACE\"\n      },\n      \"notes\": \"Python 缩进敏感，必须保持4空格缩进\"\n    },\n    {\n      \"id\": \"python_import_add\",\n      \"language\": \"python\",\n      \"scenario\": \"添加 import 语句\",\n      \"difficulty\": \"easy\",\n      \"user_request\": \"添加 typing 导入\",\n      \"context\": \"src/utils.py\",\n      \"original_code\": \"from pathlib import Path\\n\\ndef read_file(path: str):\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:src/utils.py\\nfrom pathlib import Path\\n\\ndef read_file(path: str):\\n====\\nfrom pathlib import Path\\nfrom typing import Optional\\n\\ndef read_file(path: str):\\n>>>> REPLACE\"\n      },\n      \"notes\": \"在现有 import 后添加新 import\"\n    },\n    {\n      \"id\": \"python_class_method\",\n      \"language\": \"python\",\n      \"scenario\": \"类方法修改\",\n      \"difficulty\": \"medium\",\n      \"user_request\": \"给类添加初始化方法\",\n      \"context\": \"src/user.py\",\n      \"original_code\": \"class User:\\n    pass\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:src/user.py\\nclass User:\\n    pass\\n====\\nclass User:\\n    def __init__(self, name: str, email: str):\\n        self.name = name\\n        self.email = email\\n        self.created_at = datetime.now()\\n>>>> REPLACE\"\n      },\n      \"notes\": \"类定义修改，缩进级别变化\"\n    },\n    {\n      \"id\": \"python_multiline_refactor\",\n      \"language\": \"python\",\n      \"scenario\": \"多行重构\",\n      \"difficulty\": \"medium\",\n      \"user_request\": \"重构这个函数使用早期返回\",\n      \"context\": \"src/auth.py\",\n      \"original_code\": \"def authenticate(user, token):\\n    if user:\\n        if token:\\n            if token.is_valid():\\n                return True\\n    return false\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:src/auth.py\\ndef authenticate(user, token):\\n    if user:\\n        if token:\\n            if token.is_valid():\\n                return True\\n    return False\\n====\\ndef authenticate(user, token):\\n    if not user:\\n        return False\\n    if not token:\\n        return False\\n    return token.is_valid()\\n>>>> REPLACE\"\n      },\n      \"notes\": \"代码结构重构，嵌套变为扁平\"\n    },\n    {\n      \"id\": \"python_decorator_add\",\n      \"language\": \"python\",\n      \"scenario\": \"添加装饰器\",\n      \"difficulty\": \"medium\",\n      \"user_request\": \"添加缓存装饰器\",\n      \"context\": \"src/api.py\",\n      \"original_code\": \"    def get_user(self, user_id: str):\\n        return self.db.fetch(user_id)\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:src/api.py\\n    def get_user(self, user_id: str):\\n        return self.db.fetch(user_id)\\n====\\n    @lru_cache(maxsize=128)\\n    def get_user(self, user_id: str):\\n        return self.db.fetch(user_id)\\n>>>> REPLACE\"\n      },\n      \"notes\": \"在方法前添加装饰器行\"\n    },\n    {\n      \"id\": \"typescript_interface\",\n      \"language\": \"typescript\",\n      \"scenario\": \"TypeScript 接口修改\",\n      \"difficulty\": \"easy\",\n      \"user_request\": \"添加可选字段\",\n      \"context\": \"src/types.ts\",\n      \"original_code\": \"interface User {\\n  name: string;\\n  email: string;\\n}\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:src/types.ts\\ninterface User {\\n  name: string;\\n  email: string;\\n}\\n====\\ninterface User {\\n  name: string;\\n  email: string;\\n  avatar?: string;\\n}\\n>>>> REPLACE\"\n      },\n      \"notes\": \"TypeScript 接口添加可选字段\"\n    },\n    {\n      \"id\": \"typescript_function\",\n      \"language\": \"typescript\",\n      \"scenario\": \"TypeScript 函数修改\",\n      \"difficulty\": \"medium\",\n      \"user_request\": \"改为 async 函数并添加错误处理\",\n      \"context\": \"src/api.ts\",\n      \"original_code\": \"function fetchData(url: string) {\\n  return fetch(url).then(r => r.json());\\n}\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:src/api.ts\\nfunction fetchData(url: string) {\\n  return fetch(url).then(r => r.json());\\n}\\n====\\nasync function fetchData(url: string): Promise<unknown> {\\n  const response = await fetch(url);\\n  if (!response.ok) {\\n    throw new Error(`HTTP ${response.status}`);\\n  }\\n  return response.json();\\n}\\n>>>> REPLACE\"\n      },\n      \"notes\": \"同步改异步，添加错误处理\"\n    },\n    {\n      \"id\": \"javascript_simple\",\n      \"language\": \"javascript\",\n      \"scenario\": \"JavaScript 简单修改\",\n      \"difficulty\": \"easy\",\n      \"user_request\": \"使用 const 替代 var\",\n      \"context\": \"src/utils.js\",\n      \"original_code\": \"var count = 0;\\nfunction increment() {\\n  count++;\\n}\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:src/utils.js\\nvar count = 0;\\n====\\nconst count = 0;\\n>>>> REPLACE\"\n      },\n      \"notes\": \"var 改为 const\"\n    },\n    {\n      \"id\": \"yaml_config_add\",\n      \"language\": \"yaml\",\n      \"scenario\": \"YAML 配置添加\",\n      \"difficulty\": \"medium\",\n      \"user_request\": \"添加新服务配置\",\n      \"context\": \"docker-compose.yml\",\n      \"original_code\": \"services:\\n  web:\\n    image: nginx:latest\\n    ports:\\n      - \\\"80:80\\\"\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:docker-compose.yml\\nservices:\\n  web:\\n    image: nginx:latest\\n    ports:\\n      - \\\"80:80\\\"\\n====\\nservices:\\n  web:\\n    image: nginx:latest\\n    ports:\\n      - \\\"80:80\\\"\\n  db:\\n    image: postgres:15\\n    environment:\\n      POSTGRES_DB: myapp\\n>>>> REPLACE\"\n      },\n      \"notes\": \"YAML 缩进敏感（2空格）\"\n    },\n    {\n      \"id\": \"json_config\",\n      \"language\": \"json\",\n      \"scenario\": \"JSON 配置修改\",\n      \"difficulty\": \"easy\",\n      \"user_request\": \"添加新脚本\",\n      \"context\": \"package.json\",\n      \"original_code\": \"  \\\"scripts\\\": {\\n    \\\"test\\\": \\\"jest\\\"\\n  }\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:package.json\\n  \\\"scripts\\\": {\\n    \\\"test\\\": \\\"jest\\\"\\n  }\\n====\\n  \\\"scripts\\\": {\\n    \\\"test\\\": \\\"jest\\\",\\n    \\\"lint\\\": \\\"eslint src/\\\"\\n  }\\n>>>> REPLACE\"\n      },\n      \"notes\": \"JSON 格式保持（逗号、引号）\"\n    },\n    {\n      \"id\": \"markdown_doc\",\n      \"language\": \"markdown\",\n      \"scenario\": \"Markdown 文档更新\",\n      \"difficulty\": \"easy\",\n      \"user_request\": \"添加安装说明\",\n      \"context\": \"README.md\",\n      \"original_code\": \"## Installation\\n\\nTBD\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:README.md\\n## Installation\\n\\nTBD\\n====\\n## Installation\\n\\n```bash\\nnpm install my-package\\n```\\n>>>> REPLACE\"\n      },\n      \"notes\": \"Markdown 代码块插入\"\n    },\n    {\n      \"id\": \"python_multifile\",\n      \"language\": \"python\",\n      \"scenario\": \"多文件编辑\",\n      \"difficulty\": \"medium\",\n      \"user_request\": \"同时修改模型和 schema\",\n      \"context\": \"多个文件\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:models.py\\nclass User:\\n    pass\\n====\\nclass User:\\n    def __init__(self, name: str):\\n        self.name = name\\n>>>> REPLACE\\n\\n<<<< SEARCH:schemas.py\\nclass UserSchema:\\n    pass\\n====\\nclass UserSchema:\\n    name: str\\n>>>> REPLACE\"\n      },\n      \"notes\": \"单次调用编辑多个文件\"\n    },\n    {\n      \"id\": \"python_ellipsis_anchor\",\n      \"language\": \"python\",\n      \"scenario\": \"使用省略号锚点\",\n      \"difficulty\": \"medium\",\n      \"user_request\": \"只修改函数内部\",\n      \"context\": \"src/large_file.py\",\n      \"original_code\": \"def process_data(data):\\n    # Lots of setup code...\\n    result = []\\n    for item in data:\\n        result.append(transform(item))\\n    # More code...\\n    return result\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:src/large_file.py\\n    result = []\\n    for item in data:\\n        result.append(transform(item))\\n====\\n    result = [transform(item) for item in data]\\n>>>> REPLACE\"\n      },\n      \"notes\": \"使用 ... 省略上下文（如需要）\"\n    },\n    {\n      \"id\": \"python_hallucination_fix\",\n      \"language\": \"python\",\n      \"scenario\": \"字符级幻觉容错\",\n      \"difficulty\": \"easy\",\n      \"user_request\": \"处理 LLM 字符错误\",\n      \"context\": \"src/example.py\",\n      \"original_code\": \"    if not data:\\n        return None\",\n      \"llm_attempt\": \"    if not data:\\n        returnNone\",\n      \"notes\": \"系统会自动修正 `returnNone` → `return None`\",\n      \"fuzzy_match\": true\n    },\n    {\n      \"id\": \"go_function\",\n      \"language\": \"go\",\n      \"scenario\": \"Go 函数修改\",\n      \"difficulty\": \"medium\",\n      \"user_request\": \"添加错误返回\",\n      \"context\": \"main.go\",\n      \"original_code\": \"func divide(a, b int) int {\\n    return a / b\\n}\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:main.go\\nfunc divide(a, b int) int {\\n    return a / b\\n}\\n====\\nfunc divide(a, b int) (int, error) {\\n    if b == 0 {\\n        return 0, errors.New(\\\"division by zero\\\")\\n    }\\n    return a / b, nil\\n}\\n>>>> REPLACE\"\n      },\n      \"notes\": \"Go 错误处理模式\"\n    },\n    {\n      \"id\": \"rust_function\",\n      \"language\": \"rust\",\n      \"scenario\": \"Rust 函数修改\",\n      \"difficulty\": \"medium\",\n      \"user_request\": \"添加泛型支持\",\n      \"context\": \"src/lib.rs\",\n      \"original_code\": \"fn max(a: i32, b: i32) -> i32 {\\n    if a > b { a } else { b }\\n}\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:src/lib.rs\\nfn max(a: i32, b: i32) -> i32 {\\n    if a > b { a } else { b }\\n}\\n====\\nfn max<T: Ord>(a: T, b: T) -> T {\\n    if a > b { a } else { b }\\n}\\n>>>> REPLACE\"\n      },\n      \"notes\": \"Rust 泛型语法\"\n    },\n    {\n      \"id\": \"sql_migration\",\n      \"language\": \"sql\",\n      \"scenario\": \"SQL 迁移脚本\",\n      \"difficulty\": \"medium\",\n      \"user_request\": \"添加新列\",\n      \"context\": \"migrations/001_add_users.sql\",\n      \"original_code\": \"CREATE TABLE users (\\n    id SERIAL PRIMARY KEY,\\n    name VARCHAR(255) NOT NULL\\n);\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:migrations/001_add_users.sql\\nCREATE TABLE users (\\n    id SERIAL PRIMARY KEY,\\n    name VARCHAR(255) NOT NULL\\n);\\n====\\nCREATE TABLE users (\\n    id SERIAL PRIMARY KEY,\\n    name VARCHAR(255) NOT NULL,\\n    email VARCHAR(255) UNIQUE\\n);\\n>>>> REPLACE\"\n      },\n      \"notes\": \"SQL DDL 修改\"\n    },\n    {\n      \"id\": \"css_styling\",\n      \"language\": \"css\",\n      \"scenario\": \"CSS 样式修改\",\n      \"difficulty\": \"easy\",\n      \"user_request\": \"添加响应式样式\",\n      \"context\": \"styles.css\",\n      \"original_code\": \".container {\\n    width: 100%;\\n    padding: 20px;\\n}\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:styles.css\\n.container {\\n    width: 100%;\\n    padding: 20px;\\n}\\n====\\n.container {\\n    width: 100%;\\n    padding: 20px;\\n}\\n\\n@media (max-width: 768px) {\\n    .container {\\n        padding: 10px;\\n    }\\n}\\n>>>> REPLACE\"\n      },\n      \"notes\": \"CSS 媒体查询添加\"\n    },\n    {\n      \"id\": \"html_template\",\n      \"language\": \"html\",\n      \"scenario\": \"HTML 模板修改\",\n      \"difficulty\": \"easy\",\n      \"user_request\": \"添加 meta 标签\",\n      \"context\": \"index.html\",\n      \"original_code\": \"<head>\\n    <title>My App</title>\\n</head>\",\n      \"expected_edit\": {\n        \"tool\": \"edit_blocks\",\n        \"blocks\": \"<<<< SEARCH:index.html\\n<head>\\n    <title>My App</title>\\n</head>\\n====\\n<head>\\n    <meta charset=\\\"UTF-8\\\">\\n    <meta name=\\\"viewport\\\" content=\\\"width=device-width, initial-scale=1.0\\\">\\n    <title>My App</title>\\n</head>\\n>>>> REPLACE\"\n      },\n      \"notes\": \"HTML head 添加 meta 标签\"\n    }\n  ]\n}\n