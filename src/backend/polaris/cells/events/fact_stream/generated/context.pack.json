{
  "id": "events.fact_stream",
  "title": "Events Fact Stream",
  "kind": "capability",
  "purpose": "Provide append-only runtime fact stream ingestion, fanout, and query infrastructure for PM, Director, QA and realtime projection consumers.",
  "summary": "Business capability boundary for events.fact_stream.",
  "owned_paths": [
    "polaris/kernelone/events/**",
    "polaris/infrastructure/log_pipeline/**",
    "polaris/infrastructure/realtime/process_local/message_event_fanout.py",
    "polaris/infrastructure/realtime/process_local/log_fanout.py"
  ],
  "public_contracts": {
    "commands": [
      "AppendFactEventCommandV1"
    ],
    "queries": [
      "QueryFactEventsV1"
    ],
    "events": [
      "FactEventAppendedV1"
    ],
    "results": [
      "FactStreamQueryResultV1"
    ],
    "errors": [
      "FactStreamErrorV1"
    ]
  },
  "neighbors": [
    "policy.workspace_guard",
    "audit.evidence",
    "runtime.projection"
  ],
  "state_owners": [
    "runtime/events/*"
  ],
  "effects_allowed": [
    "fs.read:runtime/events/*",
    "fs.write:runtime/events/*",
    "ws.outbound:runtime/*"
  ],
  "invariants": [
    "All state writes must remain single-owner and contract-driven.",
    "Append-only evidence and event semantics must be preserved.",
    "All text file reads and writes must use explicit UTF-8."
  ],
  "hotspots": [
    "polaris/kernelone/events/**",
    "polaris/infrastructure/log_pipeline/**",
    "polaris/infrastructure/realtime/process_local/message_event_fanout.py",
    "polaris/infrastructure/realtime/process_local/log_fanout.py"
  ],
  "test_targets": [
    "tests/test_runtime_event_fanout.py",
    "tests/test_realtime_hub_v2.py",
    "tests/test_websocket_signal_hub.py"
  ],
  "change_guidance": {
    "read_order": [
      "cell.yaml",
      "README.agent.md",
      "generated/context.pack.json",
      "public/contracts.py"
    ],
    "expand_to_neighbors_only_when_needed": true
  }
}
