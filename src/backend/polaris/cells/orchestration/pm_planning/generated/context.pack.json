{
  "id": "orchestration.pm_planning",
  "title": "PM Planning",
  "kind": "workflow",
  "purpose": "Produce PM task contracts from project goals and docs, enforce planning quality gates, and publish governed planning artifacts.",
  "summary": "Business capability boundary for orchestration.pm_planning.",
  "owned_paths": [
    "polaris/application/services/pm_service.py",
    "polaris/application/orchestration/usecases/planning_pipeline.py",
    "polaris/application/orchestration/support/task_quality_gate.py",
    "polaris/delivery/http/v2/pm.py"
  ],
  "public_contracts": {
    "commands": [
      "GeneratePmTaskContractCommandV1"
    ],
    "queries": [
      "GetPmPlanningStatusQueryV1"
    ],
    "events": [
      "PmTaskContractGeneratedEventV1"
    ],
    "results": [
      "PmTaskContractResultV1"
    ],
    "errors": [
      "PmPlanningErrorV1"
    ]
  },
  "neighbors": [
    "context.engine",
    "llm.control_plane",
    "policy.permission",
    "policy.workspace_guard",
    "runtime.state_owner",
    "audit.evidence",
    "finops.budget_guard"
  ],
  "state_owners": [
    "runtime/state/pm/*"
  ],
  "effects_allowed": [
    "fs.read:workspace/docs/*",
    "fs.read:runtime/contracts/*",
    "fs.write:runtime/state/pm/*",
    "fs.write:runtime/events/pm.events.jsonl",
    "llm.invoke:pm/*"
  ],
  "invariants": [
    "All state writes must remain single-owner and contract-driven.",
    "Append-only evidence and event semantics must be preserved.",
    "All text file reads and writes must use explicit UTF-8."
  ],
  "hotspots": [
    "polaris/application/services/pm_service.py",
    "polaris/application/orchestration/usecases/planning_pipeline.py",
    "polaris/application/orchestration/support/task_quality_gate.py",
    "polaris/delivery/http/v2/pm.py"
  ],
  "test_targets": [
    "tests/test_pm_task_quality_gate.py",
    "tests/test_pm_orchestration_api.py"
  ],
  "change_guidance": {
    "read_order": [
      "cell.yaml",
      "README.agent.md",
      "generated/context.pack.json",
      "public/contracts.py"
    ],
    "expand_to_neighbors_only_when_needed": true
  }
}
