{
  "id": "qa.audit_verdict",
  "title": "QA Audit Verdict",
  "kind": "workflow",
  "purpose": "Run independent QA or Auditor validation and emit structured acceptance verdicts for Director outputs.",
  "summary": "Business capability boundary for qa.audit_verdict.",
  "owned_paths": [
    "polaris/application/services/qa_service.py",
    "polaris/application/services/review_gate.py",
    "polaris/application/services/quality_service.py",
    "polaris/application/role_agent/qa_agent.py"
  ],
  "public_contracts": {
    "commands": [
      "RunQaAuditCommandV1"
    ],
    "queries": [
      "GetQaVerdictQueryV1"
    ],
    "events": [
      "QaVerdictIssuedEventV1"
    ],
    "results": [
      "QaAuditResultV1"
    ],
    "errors": [
      "QaAuditErrorV1"
    ]
  },
  "neighbors": [
    "director.execution",
    "policy.permission",
    "policy.workspace_guard",
    "runtime.projection",
    "audit.evidence",
    "events.fact_stream"
  ],
  "state_owners": [
    "runtime/state/qa/*"
  ],
  "effects_allowed": [
    "fs.read:workspace/**",
    "fs.read:runtime/**",
    "fs.write:runtime/state/qa/*",
    "fs.write:runtime/events/runtime.events.jsonl",
    "process.spawn:qa/*"
  ],
  "invariants": [
    "All state writes must remain single-owner and contract-driven.",
    "Append-only evidence and event semantics must be preserved.",
    "All text file reads and writes must use explicit UTF-8."
  ],
  "hotspots": [
    "polaris/application/services/qa_service.py",
    "polaris/application/services/review_gate.py",
    "polaris/application/services/quality_service.py",
    "polaris/application/role_agent/qa_agent.py"
  ],
  "test_targets": [
    "tests/test_integration_qa_command.py",
    "tests/test_quality_checker_director_tool_calls.py"
  ],
  "change_guidance": {
    "read_order": [
      "cell.yaml",
      "README.agent.md",
      "generated/context.pack.json",
      "public/contracts.py"
    ],
    "expand_to_neighbors_only_when_needed": true
  }
}
