id: workspace.integrity
title: Workspace Integrity
kind: capability
visibility: public
stateful: true
owner: workspace

purpose: >
  Provide canonical workspace validation, docs-bootstrap safety checks, code
  parsing, and file-change tracking primitives used by orchestration and
  delivery flows.

current_modules:
  - polaris.cells.workspace.integrity.public.service
  - polaris.cells.workspace.integrity.internal.workspace_service
  - polaris.cells.workspace.integrity.internal.fs_utils
  - polaris.cells.workspace.integrity.internal.code_parser
  - polaris.cells.workspace.integrity.internal.code_intel
  - polaris.cells.workspace.integrity.internal.diff_tracker

owned_paths:
  - polaris/cells/workspace/integrity/**

public_contracts:
  modules:
    - polaris.cells.workspace.integrity.public.contracts
  commands:
    - ValidateWorkspaceCommandV1
    - EnsureDocsReadyCommandV1
    - GenerateDocsTemplatesCommandV1
  queries: []
  events: []
  results:
    - DocsTemplatesResultV1
  errors:
    - WorkspaceIntegrityErrorV1

depends_on:
  - policy.workspace_guard
  - runtime.execution_broker
  - runtime.projection
  - storage.layout

subgraphs:
  - execution_governance_pipeline

state_owners:
  - workspace/meta/workspace_status.json

effects_allowed:
  - fs.read:workspace/**
  - fs.write:workspace/meta/workspace_status.json
  - fs.write:workspace/docs/**
  - process.spawn:workspace/indexer

verification:
  tests:
    - tests/test_docs_template_quality.py
    - tests/test_workspace_policy_guard.py
    - tests/test_hyper_opt.py
  gaps:
    - Code intelligence indexing strategy still relies on infrastructure adapter tuning.

