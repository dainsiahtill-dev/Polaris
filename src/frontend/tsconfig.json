{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite/client", "three"]
  },
  "include": ["src", "vite.config.ts", "tailwind.config.ts"],
  "exclude": ["src/**/__tests__/**", "src/**/*.test.*", "src/test/**"]
}
