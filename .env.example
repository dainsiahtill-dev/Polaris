# Polaris 环境变量配置示例
# 复制为 .env 文件并根据需要修改
#
# ============================================================
# DEBUG MODE - 测试阶段默认开启所有调试功能
# ============================================================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
POLARIS_LOG_LEVEL=DEBUG

# 启用详细调试追踪 (HTTP请求、子进程、LLM流等)
POLARIS_DEBUG_TRACING=true

# Electron 后端启动追踪
POLARIS_DEBUG_BACKEND_START_TRACE=true

# API 请求/响应体日志（记录请求和响应内容）
POLARIS_LOG_REQUEST_BODY=true
POLARIS_LOG_RESPONSE_BODY=true

# MCP 服务器日志级别
POLARIS_MCP_LOG_LEVEL=DEBUG

# MiniMax Provider 调试
POLARIS_MINIMAX_DEBUG=true

# LangSmith 追踪 (如配置了 LANGCHAIN_API_KEY)
LANGCHAIN_TRACING_V2=true

# ============================================================
# 项目配置
# ============================================================
POLARIS_WORKSPACE=C:\Users\dains\Documents\GitLab\polaris
POLARIS_PROJECT_NAME=Polaris

# ========== 后端服务配置 ==========
POLARIS_BACKEND_HOST=127.0.0.1
POLARIS_BACKEND_PORT=49977

# ========== 前端服务配置 ==========
POLARIS_RENDERER_PORT=5173

# ========== PM 配置 ==========
POLARIS_PM_API_HOST=127.0.0.1
POLARIS_PM_API_PORT=49980
POLARIS_PM_PROVIDER=minimax-1771264734939
POLARIS_PM_MODEL=MiniMax-M2.5

# ========== Director 配置 ==========
POLARIS_DIRECTOR_TYPE=script
POLARIS_DIRECTOR_ITERATIONS=2

# ========== 运行时配置 ==========
POLARIS_RAMDISK_ROOT=X:\
POLARIS_STATE_TO_RAMDISK=false

# ========== Hybrid / Computer Use（可选）==========
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
POLARIS_COMPUTER_USE_MODEL=computer-use-preview
# Windows 示例：根据本机安装路径修改
POLARIS_AIRTEST_CMD=airtest run scripts/vision_fallback.air --log .polaris/logs/airtest --recording "{workspace}/test-results/electron/airtest_{round}.mp4"
POLARIS_SIKULIX_CMD=java -jar C:/tools/sikulix/sikulixide.jar -r scripts/vision_fallback.sikuli -args "{prompt}" "{evidence_json}" "{round}"
